# API Base URL for Vite dev server
# Update this if DEALBOT_PORT is changed in backend
VITE_API_BASE_URL=http://localhost:8080

# Optional: enable Plausible analytics by setting the site domain
# Example values: dealbot.filoz.org or staging.dealbot.filoz.org
VITE_PLAUSIBLE_DATA_DOMAIN=

# Metrics dashboard URL linked from the per-SP rows on the landing page.
# One dashboard per environment; the app adds a vs[network] filter per row so it
# serves every network the deployment monitors (a no-op until the dashboard
# defines a {{network}} variable).
# Example: https://your-team.betteruptime.com
VITE_DASHBOARD_URL=

# Dashboard URL to embed as an iframe on the landing page (optional)
# Example: https://your-team.betteruptime.com/embed/...
VITE_DASHBOARD_EMBED_URL=

# Combined approved-SP dashboard URL linked from the landing page (optional).
# Preferred: one per-environment dashboard; the app adds a vs[network] filter.
# When set, it wins over the legacy per-network vars below.
# Example: https://telemetry.betterstack.com/dashboards/Zz8k7L?rf=now-72h&rt=now
VITE_APPROVED_SP_DASHBOARD_URL=
# Legacy per-network approved-SP dashboards (fallback used when the combined var
# above is unset). Each deployment sets the one matching its network.
VITE_APPROVED_SP_DASHBOARD_URL_MAINNET=
VITE_APPROVED_SP_DASHBOARD_URL_CALIBRATION=

# Logs URL linked from the per-SP rows on the landing page (optional).
# One dashboard per environment; the app adds a vs[network] filter per row.
VITE_LOGS_URL=
