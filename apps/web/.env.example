# API Base URL for Vite dev server
# Update this if DEALBOT_PORT is changed in backend
VITE_API_BASE_URL=http://localhost:8080

# Optional: enable Plausible analytics by setting the site domain
# Example values: dealbot.filoz.org or staging.dealbot.filoz.org
VITE_PLAUSIBLE_DATA_DOMAIN=

# Dashboard URL linked from the landing page
# Example: https://your-team.betteruptime.com
VITE_DASHBOARD_URL=

# Dashboard URL to embed as an iframe on the landing page (optional)
# Example: https://your-team.betteruptime.com/embed/...
VITE_DASHBOARD_EMBED_URL=

# Combined approved-SP dashboard URL linked from the landing page, per network (optional)
# The frontend picks the URL matching the backend's network (mainnet vs calibration).
# Example mainnet: https://telemetry.betterstack.com/dashboards/Zz8k7L?rf=now-72h&rt=now
# Example calibration: https://telemetry.betterstack.com/dashboards/wt6QCw?rf=now-3d&rt=now
VITE_APPROVED_SP_DASHBOARD_URL_MAINNET=
VITE_APPROVED_SP_DASHBOARD_URL_CALIBRATION=

# Logs URL linked from the landing page (optional)
VITE_LOGS_URL=
